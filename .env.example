APP_ENV=development

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_BASE_URL=
LLM_MODEL=CohereForAI_C4AI_Command
LLM_API_KEY=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# ── Paths (relative to PROJECT_ROOT, or absolute) ────────────────────────────
BRAIN_DIR=
KNOWLEDGE_DIR=
LOG_DIR=logs
DATA_DIR=data

# ── Watcher ───────────────────────────────────────────────────────────────────
WATCHER_ENABLED=true
WATCHER_BUFFER_TURNS=6
WATCHER_BUFFER_TIMEOUT=180
WATCHER_POLL_SECONDS=30

# ── Batch ─────────────────────────────────────────────────────────────────────
BATCH_MAX_CHARS=500000
BATCH_CHUNK_SIZE=16000
